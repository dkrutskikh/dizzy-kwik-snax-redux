{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "PACKAGE_FILE_NAME": "$env{BUILD_FILE_NAME}",
                "PACKAGE_NAME_SUFFIX": "$env{BUILD_NAME_SUFFIX}",
                "TOYGINE_BUILD_BENCHMARKS": "OFF",
                "TOYGINE_BUILD_SAMPLES": "OFF",
                "TOYGINE_BUILD_TESTS": "OFF",
                "ENABLE_PUBLIC_RELEASE": "$env{ENABLE_PUBLIC_RELEASE}",
                "ENABLE_PCH": "OFF"
            }
        },
        {
            "name": "type-debug",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "type-relwithdebinfo",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "type-release",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "platform-linux",
            "hidden": true,
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Linux Desktop"
            }
        },
        {
            "name": "platform-macos",
            "hidden": true,
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "macOS Desktop"
            }
        },
        {
            "name": "platform-macos-xcode",
            "hidden": true,
            "generator": "Xcode",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "macOS Desktop"
            }
        },
        {
            "name": "platform-windows-x64",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Windows Desktop"
            }
        },
        {
            "name": "platform-windows-x86",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "Win32",
                "strategy": "set"
            },
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Windows Desktop"
            }
        },
        {
            "name": "platform-gba",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/GBA.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo GBA"
            }
        },
        {
            "name": "platform-nds",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/NDS.cmake",
